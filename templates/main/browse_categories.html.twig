{% extends 'base.html.twig' %}
{% block title %}Home - Our Store{% endblock %}
{% block body %}
    <div class="bg-primary bg-gradient text-white py-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <h1 class="display-3 fw-bold mb-4">Welcome to Our Store</h1>
                    <p class="lead mb-4">Discover amazing products across all categories.</p>
                    <a href="{{ path('app_products') }}" class="btn btn-light btn-lg me-2">Shop Now</a>
                    <a href="#categories" class="btn btn-outline-light btn-lg">Browse Categories</a>
                </div>
                <div class="col-lg-6 text-center">
                    <img src="https://via.placeholder.com/500x400" class="img-fluid rounded" alt="Shopping">
                </div>
            </div>
        </div>
    </div>
    <div class="container my-5" id="categories">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold">Shop by Category</h2>
            <p class="text-muted">Explore our wide range of products</p>
        </div>
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            {% for category in categories %}
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <span class="badge bg-primary mb-2">{{ category.products|length }} Products</span>
                        <h4 class="card-title">{{ category.name }}</h4>
                        <p class="card-text text-muted">{{ category.desciption }}</p>
                        <a href="{{ path('app_products_by_category', {'slug': category.name}) }}" class="btn btn-outline-primary">Browse {{ category.name }}</a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
    <div class="bg-light py-5 mt-5">
        <div class="container">
            <div class="row text-center">
                <div class="col-md-4 mb-4">
                    <h5>Free Shipping</h5>
                    <p class="text-muted">On orders over $50</p>
                </div>
                <div class="col-md-4 mb-4">
                    <h5>Secure Payment</h5>
                    <p class="text-muted">100% secure transactions</p>
                </div>
                <div class="col-md-4 mb-4">
                    <h5>Easy Returns</h5>
                    <p class="text-muted">30-day return policy</p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
