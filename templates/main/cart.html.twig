{% extends 'base.html.twig' %}
{% block title %}Shopping Cart - Our Store{% endblock %}
{% block body %}
    <div class="container my-5">
        <h1 class="mb-4">Shopping Cart</h1>
        <div class="row">
            <div class="col-lg-8">
                <div class="card mb-3">
                    <div class="card-body">
                        {% if items|length > 0 %}
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th>Price</th>
                                        <th>Quantity</th>
                                        <th>Total</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for item in items %}
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <img src="https://via.placeholder.com/80" class="img-thumbnail me-3" alt="{{ item.product.name }}" style="width: 80px; height: 80px; object-fit: cover;">
                                                <div>
                                                    <h6 class="mb-0">{{ item.product.name }}</h6>
                                                    <small class="text-muted">{{ item.product.category.name }}</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>${{ item.product.price }}</td>
                                        <td>{{ item.quantity }}</td>
                                        <td class="fw-bold">${{ item.total }}</td>
                                        <td><a href="{{ path('app_cart_remove', {'id': item.product.id}) }}" class="btn btn-sm btn-outline-danger">Remove</a></td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                        {% else %}
                        <p class="text-center text-muted my-4">Your cart is empty.</p>
                        {% endif %}
                    </div>
                </div>
                <a href="{{ path('app_products') }}" class="btn btn-outline-primary">Continue Shopping</a>
            </div>
            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Order Summary</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2"><span>Subtotal:</span><span>${{ total }}</span></div>
                        <div class="d-flex justify-content-between mb-2"><span>Shipping:</span><span>$10.00</span></div>
                        <hr>
                        <div class="d-flex justify-content-between mb-3"><strong>Total:</strong><strong class="text-success">${{ total + 10 }}</strong></div>
                        <div class="d-grid"><button class="btn btn-success btn-lg">Proceed to Checkout</button></div>
                    </div>
                </div>
                {% if items|length > 0 %}
                <div class="card mt-3">
                    <div class="card-body text-center">
                        <a href="{{ path('app_cart_clear') }}" class="btn btn-outline-danger">Clear Cart</a>
                    </div>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
